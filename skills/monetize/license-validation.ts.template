// ============================================================================
// VALIDATION LOGIC
// ============================================================================

/**
 * Validate a license key
 */
export async function validateLicense(
  licenseKey: string,
  machineId?: string
): Promise<ValidationResult> {
  // Normalize key
  const normalizedKey = normalizeLicenseKey(licenseKey);

  // Check format
  if (!isValidLicenseKeyFormat(normalizedKey)) {
    return {
      valid: false,
      error: 'Invalid license key format',
      errorCode: 'INVALID_FORMAT',
    };
  }

  // Find license in database
  const license = await findLicenseByKey(normalizedKey);

  if (!license) {
    return {
      valid: false,
      error: 'License key not found',
      errorCode: 'NOT_FOUND',
    };
  }

  // Check if revoked
  if (license.revokedAt) {
    return {
      valid: false,
      license,
      error: 'License has been revoked',
      errorCode: 'REVOKED',
    };
  }

  // Check expiration
  if (license.expiresAt && new Date() > license.expiresAt) {
    return {
      valid: false,
      license,
      error: 'License has expired',
      errorCode: 'EXPIRED',
    };
  }

  // Check machine ID (if license is already activated on a different machine)
  if (license.machineId && machineId && license.machineId !== machineId) {
    return {
      valid: false,
      license,
      error: 'License is activated on a different machine',
      errorCode: 'MACHINE_MISMATCH',
    };
  }

  return {
    valid: true,
    license,
  };
}

// ============================================================================
// NEXT.JS MIDDLEWARE
// ============================================================================

import { NextResponse } from 'next/server';
import type { NextRequest } from 'next/server';

/**
 * Middleware to protect routes that require a valid license
 */
export async function licenseMiddleware(request: NextRequest) {
  // Get license key from header or cookie
  const licenseKey =
    request.headers.get('x-license-key') ||
    request.cookies.get('license_key')?.value;

  if (!licenseKey) {
    return NextResponse.json(
      { error: 'License key required' },
      { status: 401 }
    );
  }

  const validation = await validateLicense(licenseKey);

  if (!validation.valid) {
    return NextResponse.json(
      { error: validation.error, code: validation.errorCode },
      { status: 403 }
    );
  }

  // Add license info to request headers for downstream use
  const response = NextResponse.next();
  response.headers.set('x-license-valid', 'true');
  response.headers.set('x-license-email', validation.license!.email);

  return response;
}

// ============================================================================
// API ROUTES
// ============================================================================

// POST /api/licenses/activate
export async function handleActivateLicense(request: Request) {
  try {
    const { licenseKey, machineId } = await request.json();

    if (!licenseKey) {
      return NextResponse.json(
        { error: 'License key is required' },
        { status: 400 }
      );
    }

    // Validate first
    const validation = await validateLicense(licenseKey, machineId);

    if (!validation.valid) {
      return NextResponse.json(
        { error: validation.error, code: validation.errorCode },
        { status: 400 }
      );
    }

    // Activate
    const license = await activateLicense(
      normalizeLicenseKey(licenseKey),
      machineId
    );

    return NextResponse.json({
      success: true,
      message: 'License activated successfully',
      license: {
        email: license.email,
        activatedAt: license.activatedAt,
        expiresAt: license.expiresAt,
      },
    });
  } catch (error) {
    console.error('License activation error:', error);
    return NextResponse.json(
      { error: 'Failed to activate license' },
      { status: 500 }
    );
  }
}

// GET /api/licenses/validate
export async function handleValidateLicense(request: Request) {
  const { searchParams } = new URL(request.url);
  const licenseKey = searchParams.get('key');
  const machineId = searchParams.get('machineId') || undefined;

  if (!licenseKey) {
    return NextResponse.json(
      { error: 'License key is required' },
      { status: 400 }
    );
  }

  const validation = await validateLicense(licenseKey, machineId);

  return NextResponse.json({
    valid: validation.valid,
    error: validation.error,
    errorCode: validation.errorCode,
    expiresAt: validation.license?.expiresAt,
  });
}

// POST /api/licenses/deactivate
export async function handleDeactivateLicense(request: Request) {
  try {
    const { licenseKey } = await request.json();

    if (!licenseKey) {
      return NextResponse.json(
        { error: 'License key is required' },
        { status: 400 }
      );
    }

    await deactivateLicense(normalizeLicenseKey(licenseKey));

    return NextResponse.json({
      success: true,
      message: 'License deactivated successfully',
    });
  } catch (error) {
    console.error('License deactivation error:', error);
    return NextResponse.json(
      { error: 'Failed to deactivate license' },
      { status: 500 }
    );
  }
}

