}

export interface ValidationResult {
  valid: boolean;
  license?: License;
  error?: string;
  errorCode?: 'INVALID_FORMAT' | 'NOT_FOUND' | 'EXPIRED' | 'REVOKED' | 'MACHINE_MISMATCH';
}

// ============================================================================
// LICENSE KEY UTILITIES
// ============================================================================

const PRODUCT_PREFIX = '{{PRODUCT_PREFIX}}'; // e.g., 'ASEO' for Advanced SEO

/**
 * Generate a new license key
 */
export function generateLicenseKey(): string {
  const segments = Array(4)
    .fill(null)
    .map(() => crypto.randomBytes(2).toString('hex').toUpperCase());
  return `${PRODUCT_PREFIX}-${segments.join('-')}`;
}

/**
 * Validate license key format
 */
export function isValidLicenseKeyFormat(key: string): boolean {
  // Format: PROD-XXXX-XXXX-XXXX-XXXX (4 char prefix + 4 segments of 4 hex chars)
  const pattern = /^[A-Z0-9]{2,6}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{4}$/;
  return pattern.test(key.toUpperCase());
}

/**
 * Normalize license key (uppercase, trim whitespace)
 */
export function normalizeLicenseKey(key: string): string {
  return key.trim().toUpperCase().replace(/\s+/g, '');
}

