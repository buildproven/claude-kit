export async function POST(request: Request) {
  const body = await request.text();
  const headersList = await headers();
  const signature = headersList.get('stripe-signature');

  if (!signature) {
    return NextResponse.json(
      { error: 'Missing stripe-signature header' },
      { status: 400 }
    );
  }

  let event: Stripe.Event;

  try {
    event = await verifyWebhookSignature(body, signature);
  } catch (err) {
    console.error('[Webhook] Signature verification failed:', err);
    return NextResponse.json(
      { error: 'Invalid signature' },
      { status: 400 }
    );
  }

  try {
    switch (event.type) {
      case 'checkout.session.completed': {
        const session = event.data.object as Stripe.Checkout.Session;

        if (session.payment_status !== 'paid') {
          console.log('[Webhook] Payment not completed yet');
          break;
        }

        const customerEmail = session.customer_email || session.customer_details?.email;
        const customerId = session.customer as string;
        const subscriptionId = session.subscription as string | undefined;

        if (!customerEmail) {
          console.error('[Webhook] No customer email found');
          break;
        }

        // Generate license key
        const licenseKey = generateLicenseKey('{{PRODUCT_PREFIX}}');

        // Determine expiration (null for lifetime)
        let expiresAt: Date | undefined;
        if (subscriptionId) {
          const subscription = await stripe.subscriptions.retrieve(subscriptionId);
          expiresAt = new Date(subscription.current_period_end * 1000);
        }

        // Save license to database
        await saveLicense({
          licenseKey,
          email: customerEmail,
          stripeCustomerId: customerId,
          stripeSubscriptionId: subscriptionId,
          productId: '{{PRODUCT_ID}}',
          expiresAt,
        });

        // Send license email
        await sendLicenseEmail(customerEmail, licenseKey, '{{PRODUCT_NAME}}');

        console.log(`[Webhook] License created for ${customerEmail}`);
        break;
      }

      case 'customer.subscription.created': {
        const subscription = event.data.object as Stripe.Subscription;
        console.log(`[Webhook] Subscription created: ${subscription.id}`);
        // License already created in checkout.session.completed
        break;
      }

      case 'customer.subscription.deleted': {
        const subscription = event.data.object as Stripe.Subscription;
        await revokeLicense(subscription.id);
        console.log(`[Webhook] Subscription cancelled: ${subscription.id}`);
        break;
      }

      case 'customer.subscription.updated': {
        const subscription = event.data.object as Stripe.Subscription;

        // Check if subscription was cancelled (cancel_at_period_end)
        if (subscription.cancel_at_period_end) {
          console.log(`[Webhook] Subscription marked for cancellation: ${subscription.id}`);
        }
        break;
      }

      case 'invoice.payment_succeeded': {
        const invoice = event.data.object as Stripe.Invoice;
        const subscriptionId = invoice.subscription as string | undefined;

        if (subscriptionId && invoice.billing_reason === 'subscription_cycle') {
          // This is a recurring payment, extend the license
          const subscription = await stripe.subscriptions.retrieve(subscriptionId);
          const newPeriodEnd = new Date(subscription.current_period_end * 1000);
          await extendLicense(subscriptionId, newPeriodEnd);
          console.log(`[Webhook] License extended for subscription: ${subscriptionId}`);
        }
        break;
      }

      case 'invoice.payment_failed': {
        const invoice = event.data.object as Stripe.Invoice;
        console.log(`[Webhook] Payment failed for invoice: ${invoice.id}`);
        // TODO: Send payment failed email, implement grace period
        break;
      }

      default:
        console.log(`[Webhook] Unhandled event type: ${event.type}`);
    }

    return NextResponse.json({ received: true });
  } catch (err) {
    console.error('[Webhook] Error processing event:', err);
    return NextResponse.json(
      { error: 'Webhook handler failed' },
      { status: 500 }
    );
  }
}

// Disable body parsing - Stripe requires raw body for signature verification
export const config = {
  api: {
    bodyParser: false,
  },
};

