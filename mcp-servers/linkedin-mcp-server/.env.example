# LinkedIn API Credentials
# Get these from https://www.linkedin.com/developers/apps

# OAuth 2.0 Access Token (requires w_member_social scope for posting)
LINKEDIN_ACCESS_TOKEN=your_access_token

# Your LinkedIn Person URN (format: urn:li:person:XXXXXXXX)
# Find this by calling the /me endpoint with your access token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID

# OAuth App Credentials (required for automatic token refresh)
# Without these, tokens expire after 60 days and require manual renewal
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Refresh Token (obtained via oauth-setup.py script, valid ~365 days)
LINKEDIN_REFRESH_TOKEN=

# Token expiry timestamp (auto-managed by refresh logic)
LINKEDIN_TOKEN_EXPIRES_AT=
