#!/usr/bin/env bash
# collab — Generic multi-model collaboration orchestrator
#
# Usage:
#   collab init <file> [--agents "Agent1,Agent2,Agent3"]   # scaffold a new collab file
#   collab run [file]                                       # run current turn
#   collab loop <n> [file]                                  # auto-run N turns
#   collab check [file]                                     # show whose turn, no execution
#   collab status [file]                                    # full status summary
#
# Agent config (priority order):
#   1. collab.agents.json next to the collab file
#   2. ~/.collab/agents.json (global user config)
#   3. Built-in defaults (Claude Code, Codex, Gemini)
#
# Config format (JSON object, agent name → command prefix):
#   {
#     "Claude Code": "claude --dangerously-skip-permissions -p",
#     "Codex": "codex exec -c 'sandbox_permissions=[\"disk-full-read-access\",\"disk-full-write-access\"]'",
#     "My Custom Model": "mymodel --prompt"
#   }

set -euo pipefail

# ── Built-in defaults ──────────────────────────────────────────────────────────

BUILTIN_AGENTS_JSON='{
  "Claude Code": "claude --dangerously-skip-permissions -p",
  "Codex": "codex exec -c '\''sandbox_permissions=[\"disk-full-read-access\",\"disk-full-write-access\"]'\''",
  "Gemini": "gemini --yolo -p"
}'

# Done patterns — if the turn value matches any of these, the session is complete.
DONE_PATTERNS=("Done" "COMPLETE" "Notify" "notify")

# ── Helpers ────────────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

usage() {
  cat >&2 <<'EOF'
collab — Generic multi-model collaboration orchestrator

Usage:
  collab init <file> [--agents "Agent1,Agent2,..."]
  collab run   [file]      Run the current turn
  collab loop  <n> [file]  Auto-run N turns
  collab check [file]      Show whose turn it is (no execution)
  collab status [file]     Full status: turn, open items, log tail

Default file: ./AI-COLLAB.md
EOF
  exit 1
}

is_done() {
  local turn="$1"
  for pat in "${DONE_PATTERNS[@]}"; do
    if [[ "$turn" == *"$pat"* ]]; then
      return 0
    fi
  done
  return 1
}

# Load and merge agent configs into a temp JSON file.
# Merges: built-ins → global → local, with later sources winning.
load_agents_config() {
  local collab_file="$1"
  local collab_dir
  collab_dir="$(dirname "$(realpath "$collab_file")")"
  local merged_file
  merged_file="$(mktemp /tmp/collab-agents-XXXXXX)"

  # Start with built-ins
  echo "$BUILTIN_AGENTS_JSON" > "$merged_file"

  # Merge global config if present
  local global_config="$HOME/.collab/agents.json"
  if [[ -f "$global_config" ]]; then
    merged_file="$(merge_json "$merged_file" "$global_config")"
  fi

  # Merge local config if present
  local local_config="$collab_dir/collab.agents.json"
  if [[ -f "$local_config" ]]; then
    merged_file="$(merge_json "$merged_file" "$local_config")"
  fi

  echo "$merged_file"
}

# Shallow merge of two JSON objects — requires python3 (available on macOS/Linux)
merge_json() {
  local base="$1"
  local override="$2"
  local out
  out="$(mktemp /tmp/collab-merge-XXXXXX)"
  python3 -c "
import json, sys
with open('$base') as f: base = json.load(f)
with open('$override') as f: override = json.load(f)
base.update(override)
print(json.dumps(base, indent=2))
" > "$out"
  echo "$out"
}

# Look up a command for an agent name from the merged config file
get_agent_command() {
  local config_file="$1"
  local agent_name="$2"
  python3 -c "
import json, sys
with open('$config_file') as f: cfg = json.load(f)
name = sys.argv[1]
if name in cfg:
    print(cfg[name])
else:
    agents = ', '.join(f'\"{{k}}\"' for k in cfg.keys())
    print(f'ERROR: Unknown agent \"{name}\". Known agents: {agents}', file=sys.stderr)
    sys.exit(1)
" "$agent_name"
}

list_agent_names() {
  local config_file="$1"
  python3 -c "
import json
with open('$config_file') as f: cfg = json.load(f)
for k in cfg: print(f'  {k}')
"
}

# Parse the current turn from the collab file
read_turn() {
  local collab_file="$1"
  local turn
  turn="$(grep -m1 '^\*\*Whose turn:\*\*' "$collab_file" \
    | sed 's/\*\*Whose turn:\*\* //' \
    | sed 's/\*\*//g' \
    | tr -d '\r' \
    | xargs)"  # trim whitespace
  if [[ -z "$turn" ]]; then
    die "Could not find '**Whose turn:**' in $collab_file"
  fi
  echo "$turn"
}

count_open_items() {
  grep -c '| OPEN ' "$1" 2>/dev/null || true
}

count_unanswered_oqs() {
  grep -c '| UNANSWERED ' "$1" 2>/dev/null || true
}

# Run one turn for the given agent
run_agent_turn() {
  local collab_file="$1"
  local turn="$2"
  local config_file="$3"

  local abs_path
  abs_path="$(realpath "$collab_file")"
  local prompt="Read $abs_path and take your turn. Follow the ## Current Turn instructions exactly. Update the file when done."

  local cmd
  cmd="$(get_agent_command "$config_file" "$turn")"

  echo "  → Command: $cmd \"[prompt]\""
  echo ""
  eval "$cmd" "\"$prompt\""
}

# ── Subcommands ────────────────────────────────────────────────────────────────

cmd_check() {
  local collab_file="${1:-AI-COLLAB.md}"
  [[ -f "$collab_file" ]] || die "File not found: $collab_file"
  local turn
  turn="$(read_turn "$collab_file")"
  local open_items
  open_items="$(count_open_items "$collab_file")"
  local open_oqs
  open_oqs="$(count_unanswered_oqs "$collab_file")"

  echo "File: $collab_file"
  echo "Current turn: $turn"
  echo "Open items: $open_items"
  echo "Unanswered OQs: $open_oqs"

  if is_done "$turn"; then
    echo "Status: ✓ DONE"
  else
    echo "Status: in progress"
  fi
}

cmd_status() {
  local collab_file="${1:-AI-COLLAB.md}"
  [[ -f "$collab_file" ]] || die "File not found: $collab_file"
  cmd_check "$collab_file"
  echo ""
  echo "─── Last log entry ───"
  # Print from the last ### heading in the ## Log section
  awk '/^## Log/{found=1} found && /^### /{last=$0; block=""} found && last{block=block"\n"$0} END{print block}' "$collab_file" | head -20
}

cmd_run() {
  local collab_file="${1:-AI-COLLAB.md}"
  [[ -f "$collab_file" ]] || die "File not found: $collab_file"

  local turn
  turn="$(read_turn "$collab_file")"
  echo "Current turn: $turn"

  if is_done "$turn"; then
    echo "Collaboration is done. Nothing to run."
    exit 0
  fi

  local config_file
  config_file="$(load_agents_config "$collab_file")"

  echo "Running turn for: $turn"
  echo ""
  run_agent_turn "$collab_file" "$turn" "$config_file"
}

cmd_loop() {
  local max_turns="$1"
  local collab_file="${2:-AI-COLLAB.md}"
  [[ "$max_turns" =~ ^[0-9]+$ ]] || die "loop requires a numeric turn count: collab loop <n> [file]"
  [[ -f "$collab_file" ]] || die "File not found: $collab_file"

  local config_file
  config_file="$(load_agents_config "$collab_file")"

  for i in $(seq 1 "$max_turns"); do
    local turn
    turn="$(read_turn "$collab_file")"

    if is_done "$turn"; then
      echo ""
      echo "✓ Collaboration complete after $((i - 1)) turns."
      exit 0
    fi

    echo ""
    echo "════ Turn $i / $max_turns — $turn ════"
    run_agent_turn "$collab_file" "$turn" "$config_file"
  done

  echo ""
  local final_turn
  final_turn="$(read_turn "$collab_file")"
  echo "Ran $max_turns turns. Current turn: $final_turn"
}

cmd_init() {
  local collab_file="${1:-}"
  [[ -n "$collab_file" ]] || die "init requires a file name: collab init <file> [--agents 'Agent1,Agent2']"

  # Parse --agents flag
  local agents_str="Claude Code,Codex"
  shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --agents) agents_str="$2"; shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  [[ ! -f "$collab_file" ]] || die "File already exists: $collab_file"

  # Split agents into array
  IFS=',' read -ra AGENTS <<< "$agents_str"
  local first_agent="${AGENTS[0]}"
  local agent_list=""
  for a in "${AGENTS[@]}"; do
    agent_list="$agent_list- $a\n"
  done

  # Build collab.agents.json next to the file
  local agents_config_file
  agents_config_file="$(dirname "$collab_file")/collab.agents.json"

  cat > "$collab_file" << COLLAB_EOF
# AI Collaboration File

> **Purpose:** Shared read/write workspace for multi-model collaboration.
> **Agents:** $(echo "$agents_str" | tr ',' ', ')
> **Agent config:** See \`collab.agents.json\` in this directory (or use built-in defaults).

---

## How This Works

1. Brett hands off to one AI with a prompt like: "read [this file], take your turn"
2. That AI reads this file, acts on the \`## Current Turn\` section, writes its output, then sets \`## Current Turn\` to the next agent
3. Neither AI should overwrite the other's entries — append only under \`## Log\`

## Done Condition (stop the loop when ALL of these are true)

1. Zero \`OPEN\` rows remain in \`## Open Items\`
2. Zero \`UNANSWERED\` rows remain in \`## Open Questions\`
3. \`## Log\` has a final entry: "COLLAB COMPLETE"

If an AI detects all conditions are met, it writes the final log entry and sets \`## Current Turn\` to \`Done\`.

---

## Current Turn

**Whose turn:** $first_agent

**Task for $first_agent:** [Describe what this agent should do on its first turn]

---

## Open Items

| Status | ID | Finding | Severity | Notes |
|---|---|---|---|---|

Statuses: \`OPEN\` | \`PATCHED\` | \`ACCEPTED-RISK\` | \`DISPUTED\`

---

## Open Questions

| ID | Question | Status | Answer |
|---|---|---|---|

Statuses: \`UNANSWERED\` | \`ANSWERED\` | \`RESOLVED\`

---

## Log

_Entries added here by each agent after their turn._

---
COLLAB_EOF

  echo "Created: $collab_file"

  # Create collab.agents.json if any non-default agents were specified
  if [[ "$agents_str" != "Claude Code,Codex" ]]; then
    python3 -c "
import json
agents_str = '$agents_str'
names = [a.strip() for a in agents_str.split(',')]
defaults = {
    'Claude Code': 'claude --dangerously-skip-permissions -p',
    'Codex': \"codex exec -c 'sandbox_permissions=[\\\\\\"disk-full-read-access\\\\\\",\\\\\\"disk-full-write-access\\\\\\"]'\",
    'Gemini': 'gemini -p'
}
cfg = {n: defaults.get(n, f'# TODO: add command for {n}') for n in names}
print(json.dumps(cfg, indent=2))
" > "$agents_config_file"
    echo "Created: $agents_config_file  (review and fill in any TODO commands)"
  fi

  echo ""
  echo "Agents: $(echo "$agents_str" | tr ',' ', ')"
  echo "First turn: $first_agent"
  echo ""
  echo "Run:  collab check $collab_file"
  echo "Run:  collab run $collab_file"
}

# ── Entry point ────────────────────────────────────────────────────────────────

[[ $# -gt 0 ]] || usage

SUBCOMMAND="$1"
shift

case "$SUBCOMMAND" in
  init)   cmd_init "$@" ;;
  run)    cmd_run "$@" ;;
  loop)   cmd_loop "$@" ;;
  check)  cmd_check "$@" ;;
  status) cmd_status "$@" ;;
  --help|-h|help) usage ;;
  *) die "Unknown subcommand: '$SUBCOMMAND'. Use: init, run, loop, check, status" ;;
esac
